# ============================================================
# .env.example  —  Environment Variable Template
# Fitness Goal Tracker API
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# Set these same variables in your Render dashboard under
# Environment > Environment Variables.
# ============================================================

# ── Server ───────────────────────────────────────────────────
# Port Render (or any PaaS) will inject this automatically.
# Leave it out of your production env vars — Render sets it.
PORT=5000

# ── MongoDB Atlas ─────────────────────────────────────────────
# Full connection string from MongoDB Atlas → Connect →
# "Connect your application" → Driver: Node.js
# Replace <username>, <password>, and <cluster> with your values.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=<appName>

# ── JWT ───────────────────────────────────────────────────────
# A long random string used to sign tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars

# How long tokens stay valid.  Examples: 7d  24h  30d
JWT_EXPIRES_IN=7d

# ── CORS / Frontend URL ───────────────────────────────────────
# The origin(s) allowed to call this API.
# In production set this to your deployed frontend URL.
# Multiple origins: comma-separated, no spaces.
#   e.g. CLIENT_URL=https://my-app.onrender.com
#   e.g. CLIENT_URL=https://my-app.onrender.com,https://my-app.netlify.app
CLIENT_URL=http://localhost:5500

# ── Node Environment ──────────────────────────────────────────
# Use "production" on Render/Heroku/Railway.
# The error handler uses this to hide stack traces from clients.
NODE_ENV=development
